(function () {
  const payload = window.HERMES_STATIC_REPORT_READER_INDEX || { reports: [], stats: {} };
  const reports = Array.isArray(payload.reports) ? payload.reports : [];
  const pageLimit = 50;
  function defaultDateFrom() {
    const d = new Date();
    d.setDate(d.getDate() - 3);
    return d.toISOString().slice(0, 10);
  }
  const state = {
    query: "",
    reportType: "",
    dateFrom: defaultDateFrom(),
    dateTo: "",
    hasTargetPrice: "",
    sort: "date_desc",
    loadedCount: pageLimit,
    selectedId: "",
    dark: localStorage.getItem("hermes_simple_reader_theme") === "dark",
  };

  const els = {
    title: document.querySelector("#app-title"),
    query: document.querySelector("#library-query"),
    reportType: document.querySelector("#library-report-type"),
    dateFrom: document.querySelector("#library-date-from"),
    dateTo: document.querySelector("#library-date-to"),
    hasTargetPrice: document.querySelector("#library-target-price"),
    sort: document.querySelector("#library-sort"),
    status: document.querySelector("#library-status"),
    prev: document.querySelector("#library-prev"),
    next: document.querySelector("#library-next"),
    rows: document.querySelector("#library-rows"),
    detail: document.querySelector("#library-detail"),
    mobileSelection: document.querySelector("#library-mobile-selection"),
    drawerToggle: document.querySelector("#library-drawer-toggle"),
    drawerClose: document.querySelector("#library-drawer-close"),
    drawerBackdrop: document.querySelector("#library-drawer-backdrop"),
  };

  init();

  function init() {
    document.title = payload.title || "Hermes 報告庫";
    els.title.textContent = payload.title || "報告庫";
    applyTheme();
    fillReportTypes();
    // 預設 dateFrom 寫進 input (3 天內)
    if (els.dateFrom && state.dateFrom) els.dateFrom.value = state.dateFrom;
    bindControls();
    bindInfiniteScroll();
    bindHeaderSort();
    render();
  }

  function bindControls() {
    els.query.addEventListener("input", () => {
      state.query = els.query.value.trim().toLowerCase();
      state.loadedCount = pageLimit;
      render();
    });
    els.reportType.addEventListener("change", () => {
      state.reportType = els.reportType.value;
      state.loadedCount = pageLimit;
      render();
    });
    els.dateFrom.addEventListener("change", () => {
      state.dateFrom = els.dateFrom.value;
      state.loadedCount = pageLimit;
      render();
    });
    els.dateTo.addEventListener("change", () => {
      state.dateTo = els.dateTo.value;
      state.loadedCount = pageLimit;
      render();
    });
    els.hasTargetPrice.addEventListener("change", () => {
      state.hasTargetPrice = els.hasTargetPrice.value;
      state.loadedCount = pageLimit;
      render();
    });
    els.sort.addEventListener("change", () => {
      state.sort = els.sort.value;
      state.loadedCount = pageLimit;
      render();
    });
    // 隱藏分頁按鈕，改用無限滾動
    if (els.prev) els.prev.style.display = "none";
    if (els.next) els.next.style.display = "none";
    els.drawerToggle?.addEventListener("click", openDrawer);
    els.drawerClose?.addEventListener("click", closeDrawer);
    els.drawerBackdrop?.addEventListener("click", closeDrawer);
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeDrawer();
      if (event.key === "ArrowUp") selectAdjacent(-1);
      if (event.key === "ArrowDown") selectAdjacent(1);
    });
  }

  function render() {
    const filtered = sortedReports(reports.filter(matchesFilters));
    const page = filtered.slice(0, state.loadedCount);
    const selected = page.find((report) => report.id === state.selectedId) || page[0] || null;
    state.selectedId = selected?.id || "";
    renderRows(page);
    renderStatus(filtered.length, page.length);
    renderDetail(selected);
    updateMobileSelection(selected);
  }

  function bindInfiniteScroll() {
    const scroller = document.querySelector(".table-wrap");
    if (!scroller) return;
    scroller.addEventListener("scroll", () => {
      const { scrollTop, scrollHeight, clientHeight } = scroller;
      if (scrollHeight - scrollTop - clientHeight < 300) {
        const filteredLen = reports.filter(matchesFilters).length;
        if (state.loadedCount < filteredLen) {
          state.loadedCount = Math.min(filteredLen, state.loadedCount + pageLimit);
          render();
        }
      }
    });
  }

  function bindHeaderSort() {
    const dateHead = document.querySelector("#library-head-date");
    if (!dateHead) return;
    dateHead.style.cursor = "pointer";
    dateHead.title = "點擊切換升降冪";
    dateHead.addEventListener("click", () => {
      state.sort = state.sort === "date_desc" ? "date_asc" : "date_desc";
      state.loadedCount = pageLimit;
      if (els.sort) els.sort.value = state.sort.startsWith("date") ? state.sort : "date_desc";
      // 顯示箭頭
      dateHead.textContent = state.sort === "date_desc" ? "日期 ↓" : "日期 ↑";
      render();
    });
    dateHead.textContent = "日期 ↓";
  }

  function matchesFilters(report) {
    const reportType = report.report_type || report.category || "";
    if (state.reportType && reportType !== state.reportType) return false;
    if (state.dateFrom && report.date < state.dateFrom) return false;
    if (state.dateTo && report.date > state.dateTo) return false;
    if (state.hasTargetPrice === "true" && !report.has_target_price) return false;
    if (state.query && !String(report.search_text || "").includes(state.query)) return false;
    return true;
  }

  function sortedReports(rows) {
    const sorted = [...rows];
    sorted.sort((a, b) => {
      if (state.sort === "target_price_desc") return targetSort(a, b, true);
      if (state.sort === "target_price_asc") return targetSort(a, b, false);
      if (state.sort === "date_asc") return compareText(a.date, b.date) || compareText(a.category, b.category) || compareText(a.id, b.id);
      return compareText(b.date, a.date) || compareText(a.category, b.category) || compareText(a.id, b.id);
    });
    return sorted;
  }

  function renderRows(page) {
    els.rows.innerHTML = page.map((report) => `
      <tr class="${report.id === state.selectedId ? "selected" : ""}" data-report-id="${escapeHtml(report.id)}">
        <td data-label="上傳日" title="上傳 ${escapeHtml(report.uploaded_at || report.date || "")}">${escapeHtml(compactDate(report.uploaded_at || report.date))}</td>
        <td data-label="報告">
          <span class="row-topic" title="${escapeHtml(subject(report))}">${escapeHtml(subject(report))}</span>
          <span class="row-report-meta">${escapeHtml(rowMeta(report))}</span>
        </td>
      </tr>
    `).join("");
    els.rows.querySelectorAll("tr").forEach((row) => {
      row.addEventListener("click", () => {
        const report = page.find((item) => item.id === row.dataset.reportId);
        state.selectedId = report?.id || "";
        renderRows(page);
        renderDetail(report || null);
        updateMobileSelection(report || null);
        closeDrawer();
      });
    });
  }

  function renderStatus(total, returned) {
    if (!total) {
      els.status.textContent = "0 筆 (試擴大日期區間)";
      return;
    }
    if (returned >= total) {
      els.status.textContent = `共 ${total.toLocaleString()} 筆`;
    } else {
      els.status.textContent = `已載入 ${returned.toLocaleString()} / ${total.toLocaleString()} 筆 (繼續往下滾)`;
    }
  }

  function renderPager(total) {
    els.prev.disabled = state.offset <= 0;
    els.next.disabled = state.offset + pageLimit >= total;
  }

  function renderDetail(report) {
    if (!report) {
      els.detail.innerHTML = `
        <p class="eyebrow">沒有結果</p>
        <h2>找不到符合條件的報告。</h2>
        <p class="muted">請放寬日期區間、改用股號搜尋，或切換其他報告分類。</p>
      `;
      return;
    }
    const href = report.pdf_href || "";
    els.detail.innerHTML = `
      <div class="reader-toolbar">
        <div class="reader-nav">
          <button class="reader-nav-button" type="button" data-reader-prev>上一份</button>
          <button class="reader-nav-button" type="button" data-reader-next>下一份</button>
        </div>
        <div class="reader-toolbar-actions">
          <button class="secondary-action" type="button" data-theme-toggle aria-pressed="${state.dark ? "true" : "false"}">${state.dark ? "亮色" : "深色"}</button>
          ${href ? `<a class="secondary-action" href="${escapeHtml(href)}" target="_blank" rel="noreferrer">開啟 PDF</a>` : ""}
        </div>
      </div>
      <section class="reader-pane active">
        ${href ? `
          <div class="pdf-preview">
            <iframe src="${escapeHtml(href)}" title="PDF preview" loading="lazy"></iframe>
          </div>
        ` : `
          <div class="pdf-empty">
            <p>這份報告沒有本機同步 PDF。</p>
          </div>
        `}
      </section>
    `;
    els.detail.querySelector("[data-reader-prev]")?.addEventListener("click", () => selectAdjacent(-1));
    els.detail.querySelector("[data-reader-next]")?.addEventListener("click", () => selectAdjacent(1));
    els.detail.querySelector("[data-theme-toggle]")?.addEventListener("click", toggleTheme);
  }

  function selectAdjacent(delta) {
    const rows = Array.from(els.rows.querySelectorAll("tr"));
    const index = rows.findIndex((row) => row.dataset.reportId === state.selectedId);
    const next = rows[index + delta];
    if (!next) return;
    next.scrollIntoView({ block: "nearest" });
    next.click();
  }

  function fillReportTypes() {
    const preferred = ["個股", "海外個股", "產業", "總經", "策略刊物"];
    const values = uniqueValues(reports.map((report) => report.report_type || report.category));
    const ordered = preferred.filter((value) => values.includes(value)).concat(values.filter((value) => !preferred.includes(value)));
    els.reportType.innerHTML = `<option value="">全部報告</option>` + ordered.map((value) => `<option value="${escapeHtml(value)}">${escapeHtml(value)}</option>`).join("");
  }

  function openDrawer() {
    document.body.classList.add("library-drawer-open");
  }

  function closeDrawer() {
    document.body.classList.remove("library-drawer-open");
  }

  function toggleTheme() {
    state.dark = !state.dark;
    localStorage.setItem("hermes_simple_reader_theme", state.dark ? "dark" : "light");
    applyTheme();
    const button = els.detail.querySelector("[data-theme-toggle]");
    if (button) {
      button.textContent = state.dark ? "亮色" : "深色";
      button.setAttribute("aria-pressed", state.dark ? "true" : "false");
    }
  }

  function applyTheme() {
    document.body.classList.toggle("report-library-dark", state.dark);
  }

  function updateMobileSelection(report) {
    els.mobileSelection.textContent = report ? selectedSummary(report) : els.status.textContent || "選擇報告";
  }

  function subject(report) {
    return report.display_subject || report.title || report.source_file || report.id || "Report";
  }

  function selectedSummary(report) {
    return [compactDate(report.date), subject(report)].filter(Boolean).join(" ") + (report.broker ? ` · ${report.broker}` : "");
  }

  function rowMeta(report) {
    const analysts = Array.isArray(report.analysts) && report.analysts.length
      ? report.analysts.join("、") : "";
    return [
      report.date || "",
      report.report_type || report.category || "",
      report.broker || "",
      analysts,
      targetPriceLabel(report),
    ].filter(Boolean).join(" · ");
  }

  function targetPriceLabel(report) {
    if (!report.has_target_price) return "";
    if (report.target_price_currency === "MIXED") return report.target_price_raw || "多標的";
    const value = Number(report.target_price_sort_value);
    if (!Number.isFinite(value)) return report.target_price_raw || "";
    return [report.target_price_currency, new Intl.NumberFormat("en-US", { maximumFractionDigits: 2 }).format(value)]
      .filter(Boolean)
      .join(" ");
  }

  function compactDate(value) {
    const match = String(value || "").match(/^20\d{2}-(\d{2})-(\d{2})$/);
    return match ? `${match[1]}-${match[2]}` : value || "";
  }

  function targetSort(a, b, descending) {
    const aHas = Boolean(a.has_target_price);
    const bHas = Boolean(b.has_target_price);
    if (aHas !== bHas) return aHas ? -1 : 1;
    const aValue = Number(a.target_price_sort_value || 0);
    const bValue = Number(b.target_price_sort_value || 0);
    if (aValue !== bValue) return descending ? bValue - aValue : aValue - bValue;
    return compareText(b.date, a.date);
  }

  function uniqueValues(values) {
    return [...new Set(values.map((value) => String(value || "").trim()).filter(Boolean))]
      .sort((a, b) => a.localeCompare(b, "zh-Hant"));
  }

  function compareText(a, b) {
    return String(a || "").localeCompare(String(b || ""), "zh-Hant");
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }
})();
